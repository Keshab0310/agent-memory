{
  "description": "agent-memory: auto-compress tool output, inject memory context",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write|Grep|Glob|Bash|WebFetch|WebSearch|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"$HOME/.claude/plugins/marketplaces/Keshab0310/plugin\"; python \"$_R/hooks/post_tool_use.py\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"$HOME/.claude/plugins/marketplaces/Keshab0310/plugin\"; python \"$_R/hooks/session_start.py\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
